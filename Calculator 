def add(a,b):
    return a+b

def sub(a,b):
    return a-b

def mul(a,b):
    return a*b

def div(a,b):
    return a/b

num1 = float(input("Enter number 1: "))
num2 = float(input("Enter number 2: "))
op = input("Choose operation (+,-,*,/): ")

if op == "+":
    print("Answer:", add(num1,num2))
elif op == "-":
    print("Answer:", sub(num1,num2))
elif op == "*":
    print("Answer:", mul(num1,num2))
elif op == "/":
    print("Answer:", div(num1,num2))